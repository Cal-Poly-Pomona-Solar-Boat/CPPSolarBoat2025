/* ================================================================
 * CLOSED-LOOP STEERING CONTROL
 * ================================================================
 *
 * Topology:
 *   AS5600 #1  (I2C3) — steering wheel, tracked as delta from boot zero
 *   AS5600 #2  (I2C4) — left  rudder actuator feedback
 *   AS5600 #3  (I2C2) — right rudder actuator feedback
 *
 * Physical limits:  rudder travel ±35 deg
 * Target:           full 70 deg sweep achievable in ≤ 1 second
 *
 * Pulse math (verify against your DM860I dip switch setting):
 *   Microstepping : 1600 pulse/rev  (SW5=on SW6=off SW7=on SW8=on)
 *   Gearbox       : 20:1
 *   Output deg/pulse = 360 / (1600 × 20) = 0.01125 deg
 *   Pulses for 70 deg = 70 / 0.01125 ≈ 6222 pulses
 *   At STEP_RATE_MAX = 8000 pulse/s → 6222/8000 ≈ 0.78 s  ✓
 * ================================================================ */

#define RATE_STEERING_CTRL_MS    2U           // control loop period (ms)

/* Timer clock — TIM8 and TIM15 both on APB2 = 170 MHz, prescaler 0 */
#define TIM8_CLK_HZ              170000000.0f

/* Step-rate limits */
#define STEP_RATE_MAX            8000.0f      // pulse/s  ≈ 90 deg/s output
#define STEP_RATE_MIN            80.0f        // below this → motor stopped
#define STEP_RATE_SLEW           4000.0f      // max rate change per 2 ms tick

/* Rudder physical travel limits */
#define RUDDER_DEG_MAX           35.0f
#define RUDDER_DEG_MIN          -35.0f

/*
 * WHEEL_DEG_RANGE — how many degrees the steering-wheel AS5600
 * physically rotates from centre to full lock (one side).
 * If wheel and rudder have identical travel, set this to 35.0f.
 * If wheel rotates ±90 deg for ±35 deg rudder, set to 90.0f.
 */
#define WHEEL_DEG_RANGE          35.0f

/* PID deadband and integral zone */
#define STEER_DEADBAND_DEG       0.3f
#define STEER_INT_ZONE_DEG       5.0f

/* PID gains — tune Kp first on bench, then Ki, then Kd */
#define STEER_KP                 200.0f
#define STEER_KI                 40.0f
#define STEER_KD                 8.0f

